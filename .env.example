# VerifiedSXO Environment Variables
# Copy this to .env.local and fill in your values

# Anthropic API Key (powers the verification engine)
ANTHROPIC_API_KEY=

# NextAuth.js (required for LinkedIn authentication)
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://your-domain.com

# LinkedIn OAuth (optional - for sign-in)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Python Backend URL (optional - for NotebookLM integration in Phase 2)
# BACKEND_URL=https://your-backend.com
